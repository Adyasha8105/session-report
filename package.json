{
  "name": "session-report",
  "version": "1.0.8",
  "description": "Export AI coding assistant sessions (Claude Code, Codex CLI, Cursor) to PDF, DOCX, MD, or JSON",
  "type": "module",
  "bin": {
    "session-report": "./dist/index.cjs"
  },
  "main": "./dist/index.cjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "echo 'Publishing session-report'"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "docx": "^9.0.0",
    "fast-glob": "^3.3.2",
    "highlight.js": "^11.9.0",
    "marked": "^13.0.0",
    "marked-highlight": "^2.1.3",
    "ora": "^8.0.1",
    "p-limit": "^6.1.0",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.0.0",
    "@types/pdfkit": "^0.17.5",
    "esbuild": "^0.21.5",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
